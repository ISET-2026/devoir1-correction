<!DOCTYPE html>
<html lang="fr" data-bs-theme="light">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}GestProjet
			{% endblock %}
			| Gestion de Projets Académiques</title>
		<meta name="description" content="Application de gestion de projets académiques universitaires">
		<link
		rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎓</text></svg>">

		{# Bootstrap 5 CSS #}
		<link
		href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
		{# Bootstrap Icons #}
		<link
		href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
		{# Google Fonts #}
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

		<style>:root
		{
			--gp-primary: #4f46e5;
			--gp-primary-light: #818cf8;
			--gp-primary-dark: #3730a3;
			--gp-secondary: #0ea5e9;
			--gp-accent: #8b5cf6;
			--gp-surface: #f8fafc;
			--gp-card-bg: #ffffff;
			--gp-gradient: linear-gradient(135deg, var(--gp-primary) 0%, var(--gp-accent) 50%, var(--gp-secondary) 100%);
			--gp-gradient-subtle: linear-gradient(135deg, #eef2ff 0%, #f0f9ff 100%);
			--gp-shadow: 0 1px 3px rgba(0, 0, 0, .06), 0 1px 2px rgba(0, 0, 0, .04);
			--gp-shadow-md: 0 4px 6px -1px rgba(0, 0, 0, .07), 0 2px 4px rgba(0, 0, 0, .04);
			--gp-shadow-lg: 0 10px 25px -3px rgba(0, 0, 0, .08), 0 4px 6px rgba(0, 0, 0, .03);
			--gp-radius: 12px;
			--gp-radius-lg: 16px;
		}

		* {
			font-family: 'Inter', system-ui, sans-serif;
		}

		body {
			background: var(--gp-surface);
			min-height: 100vh;
			display: flex;
			flex-direction: column;
		}

		/* ─── Navbar ─── */
		.navbar-gp {
			background: var(--gp-gradient);
			padding: 0.75rem 0;
			box-shadow: 0 4px 20px rgba(79, 70, 229, .25);
		}
		.navbar-gp .navbar-brand {
			font-weight: 800;
			font-size: 1.35rem;
			letter-spacing: -0.5px;
			color: #fff !important;
		}
		.navbar-gp .nav-link {
			color: rgba(255, 255, 255, .85) !important;
			font-weight: 500;
			border-radius: 8px;
			padding: 0.45rem 0.9rem !important;
			transition: all 0.2s;
		}
		.navbar-gp .nav-link:hover,
		.navbar-gp .nav-link.active {
			color: #fff !important;
			background: rgba(255, 255, 255, .15);
		}
		.navbar-gp .nav-link i {
			margin-right: 0.35rem;
		}

		/* ─── Cards ─── */
		.card-gp {
			background: var(--gp-card-bg);
			border: 1px solid rgba(0, 0, 0, .06);
			border-radius: var(--gp-radius-lg);
			box-shadow: var(--gp-shadow);
			transition: transform 0.2s, box-shadow 0.2s;
		}
		.card-gp:hover {
			transform: translateY(-2px);
			box-shadow: var(--gp-shadow-lg);
		}

		/* ─── Stat Cards ─── */
		.stat-card {
			border-radius: var(--gp-radius-lg);
			padding: 1.5rem;
			position: relative;
			overflow: hidden;
			color: #fff;
		}
		.stat-card::after {
			content: '';
			position: absolute;
			top: -30%;
			right: -20%;
			width: 120px;
			height: 120px;
			border-radius: 50%;
			background: rgba(255, 255, 255, .12);
		}
		.stat-card .stat-icon {
			width: 48px;
			height: 48px;
			background: rgba(255, 255, 255, .2);
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.3rem;
			margin-bottom: 0.75rem;
		}
		.stat-card .stat-value {
			font-size: 2rem;
			font-weight: 800;
			line-height: 1;
		}
		.stat-card .stat-label {
			font-size: 0.85rem;
			opacity: .85;
			margin-top: 0.25rem;
		}

		.stat-projets {
			background: linear-gradient(135deg, #4f46e5, #7c3aed);
		}
		.stat-enseignants {
			background: linear-gradient(135deg, #0ea5e9, #06b6d4);
		}
		.stat-etudiants {
			background: linear-gradient(135deg, #f59e0b, #ef4444);
		}
		.stat-termines {
			background: linear-gradient(135deg, #10b981, #059669);
		}

		/* ─── Page Header ─── */
		.page-header {
			background: var(--gp-gradient-subtle);
			border-radius: var(--gp-radius-lg);
			padding: 2rem;
			margin-bottom: 1.5rem;
			border: 1px solid rgba(79, 70, 229, .08);
		}
		.page-header h1 {
			font-weight: 800;
			font-size: 1.75rem;
			letter-spacing: -0.5px;
			color: var(--gp-primary-dark);
			margin: 0;
		}
		.page-header p {
			color: #64748b;
			margin: 0.25rem 0 0;
		}

		/* ─── Tables ─── */
		.table-gp {
			border-collapse: separate;
			border-spacing: 0;
		}
		.table-gp thead th {
			background: #f1f5f9;
			font-weight: 600;
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 0.5px;
			color: #475569;
			border: none;
			padding: 0.85rem 1rem;
		}
		.table-gp thead th:first-child {
			border-radius: 10px 0 0 0;
		}
		.table-gp thead th:last-child {
			border-radius: 0 10px 0 0;
		}
		.table-gp tbody tr {
			transition: background 0.15s;
		}
		.table-gp tbody tr:hover {
			background: #f8fafc;
		}
		.table-gp tbody td {
			padding: 0.85rem 1rem;
			vertical-align: middle;
			border-bottom: 1px solid #f1f5f9;
		}

		/* ─── Buttons ─── */
		.btn-gp-primary {
			background: var(--gp-gradient);
			border: none;
			color: #fff;
			font-weight: 600;
			border-radius: 10px;
			padding: 0.55rem 1.25rem;
			transition: all 0.2s;
			box-shadow: 0 2px 8px rgba(79, 70, 229, .25);
		}
		.btn-gp-primary:hover {
			transform: translateY(-1px);
			box-shadow: 0 4px 16px rgba(79, 70, 229, .35);
			color: #fff;
		}

		.btn-gp-outline {
			border: 1.5px solid var(--gp-primary);
			color: var(--gp-primary);
			font-weight: 600;
			border-radius: 10px;
			padding: 0.55rem 1.25rem;
			transition: all 0.2s;
			background: transparent;
		}
		.btn-gp-outline:hover {
			background: var(--gp-primary);
			color: #fff;
		}

		/* ─── Badges ─── */
		.badge {
			font-weight: 600;
			padding: 0.45em 0.8em;
			border-radius: 8px;
		}

		/* ─── Forms ─── */
		.form-control,
		.form-select {
			border-radius: 10px;
			border: 1.5px solid #e2e8f0;
			padding: 0.6rem 0.9rem;
			transition: border-color 0.2s, box-shadow 0.2s;
		}
		.form-control:focus,
		.form-select:focus {
			border-color: var(--gp-primary-light);
			box-shadow: 0 0 0 3px rgba(79, 70, 229, .1);
		}
		.form-label {
			font-weight: 600;
			font-size: 0.875rem;
			color: #334155;
			margin-bottom: 0.35rem;
		}

		/* ─── Flash Messages ─── */
		.alert {
			border-radius: var(--gp-radius);
			border: none;
			font-weight: 500;
		}

		/* ─── Empty State ─── */
		.empty-state {
			text-align: center;
			padding: 3rem 1rem;
			color: #94a3b8;
		}
		.empty-state i {
			font-size: 3.5rem;
			margin-bottom: 1rem;
			opacity: .5;
		}
		.empty-state h5 {
			color: #64748b;
			font-weight: 600;
		}

		/* ─── Footer ─── */
		.footer-gp {
			margin-top: auto;
			background: #1e293b;
			color: rgba(255, 255, 255, .6);
			padding: 1.25rem 0;
			font-size: 0.85rem;
		}
		.footer-gp a {
			color: var(--gp-primary-light);
			text-decoration: none;
		}

		/* ─── Animations ─── */
		@keyframes fadeInUp {
			from {
				opacity: 0;
				transform: translateY(20px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
		.fade-in-up {
			animation: fadeInUp 0.4s ease-out both;
		}
		.fade-in-up:nth-child(2) {
			animation-delay: 0.05s;
		}
		.fade-in-up:nth-child(3) {
			animation-delay: 0.1s;
		}
		.fade-in-up:nth-child(4) {
			animation-delay: 0.15s;
		}

		/* ─── Sort Link ─── */
		.sort-link {
			color: inherit;
			text-decoration: none;
		}
		.sort-link:hover {
			color: var(--gp-primary);
		}
	</style>

	{% block stylesheets %}{% endblock %}
</head>
<body>
	{# ── Navigation ── #}
	<nav class="navbar navbar-expand-lg navbar-gp">
		<div class="container">
			<a class="navbar-brand" href="{{ path('app_home') }}">
				🎓 GestProjet
			</a>
			<button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navMain">
				<ul class="navbar-nav ms-auto gap-1">
					<li class="nav-item">
						<a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_home' ? 'active' }}" href="{{ path('app_home') }}">
							<i class="bi bi-house-door-fill"></i>
							Accueil
						</a>
					</li>
					<li class="nav-item">
						<a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_projet' ? 'active' }}" href="{{ path('app_projet_index') }}">
							<i class="bi bi-kanban-fill"></i>
							Projets
						</a>
					</li>
					<li class="nav-item">
						<a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_enseignant' ? 'active' }}" href="{{ path('app_enseignant_index') }}">
							<i class="bi bi-person-badge-fill"></i>
							Enseignants
						</a>
					</li>
					<li class="nav-item">
						<a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_etudiant' ? 'active' }}" href="{{ path('app_etudiant_index') }}">
							<i class="bi bi-mortarboard-fill"></i>
							Étudiants
						</a>
					</li>
				</ul>
			</div>
		</div>
	</nav>

	{# ── Flash Messages ── #}
	<div class="container mt-3">
		{% for label, messages in app.flashes %}
			{% for message in messages %}
				<div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
					{% if label == 'success' %}
						<i class="bi bi-check-circle-fill me-2"></i>
					{% elseif label == 'danger' %}
						<i class="bi bi-exclamation-triangle-fill me-2"></i>
					{% elseif label == 'warning' %}
						<i class="bi bi-exclamation-circle-fill me-2"></i>
					{% else %}
						<i class="bi bi-info-circle-fill me-2"></i>
					{% endif %}
					{{ message }}
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			{% endfor %}
		{% endfor %}
	</div>

	{# ── Main Content ── #}
	<main class="container py-4 flex-grow-1"> {% block body %}{% endblock %}
		</main>

		{# ── Footer ── #}
		<footer class="footer-gp">
			<div class="container text-center">
				<span>©
					{{ 'now'|date('Y') }}
					<strong>GestProjet</strong>
					— Application de gestion de projets académiques</span>
			</div>
		</footer>

		{# Bootstrap JS #}
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
		{% block javascripts %}{% endblock %}
	</body>
</html>
