{% extends 'base.html.twig' %}

{% block title %}Modifier «
	{{ etudiant.nom }}
	»
{% endblock %}

{% block body %}
	<nav aria-label="breadcrumb" class="mb-3">
		<ol class="breadcrumb">
			<li class="breadcrumb-item">
				<a href="{{ path('app_home') }}" class="text-decoration-none">Accueil</a>
			</li>
			<li class="breadcrumb-item">
				<a href="{{ path('app_etudiant_index') }}" class="text-decoration-none">Étudiants</a>
			</li>
			<li class="breadcrumb-item">
				<a href="{{ path('app_etudiant_show', {id: etudiant.id}) }}" class="text-decoration-none">{{ etudiant.nom }}</a>
			</li>
			<li class="breadcrumb-item active">Modifier</li>
		</ol>
	</nav>

	<div class="row justify-content-center">
		<div class="col-lg-6">
			<div class="card-gp p-4">
				<h2 class="fw-bold mb-4">
					<i class="bi bi-pencil-fill text-warning me-2"></i>Modifier l'étudiant</h2>
				{% include 'etudiant/_form.html.twig' with {button_label: 'Enregistrer', button_icon: 'bi-check-lg'} %}
			</div>
		</div>
	</div>
{% endblock %}
