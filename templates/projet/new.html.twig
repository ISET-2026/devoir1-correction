{% extends 'base.html.twig' %}

{% block title %}Nouveau projet
{% endblock %}

{% block body %}
	<nav aria-label="breadcrumb" class="mb-3">
		<ol class="breadcrumb">
			<li class="breadcrumb-item">
				<a href="{{ path('app_home') }}" class="text-decoration-none">Accueil</a>
			</li>
			<li class="breadcrumb-item">
				<a href="{{ path('app_projet_index') }}" class="text-decoration-none">Projets</a>
			</li>
			<li class="breadcrumb-item active">Nouveau</li>
		</ol>
	</nav>

	<div class="row justify-content-center">
		<div class="col-lg-8">
			<div class="card-gp p-4">
				<h2 class="fw-bold mb-4">
					<i class="bi bi-plus-circle-fill text-primary me-2"></i>Nouveau projet</h2>
				{% include 'projet/_form.html.twig' with {button_label: 'Créer le projet', button_icon: 'bi-plus-lg'} %}
			</div>
		</div>
	</div>
{% endblock %}
